{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/user/quality-zero-platform/schemas/qzp-finding-v1.json",
  "title": "QZP Finding v1",
  "description": "Canonical finding schema for Quality Rollup v2.",
  "type": "object",
  "required": [
    "schema_version",
    "finding_id",
    "file",
    "line",
    "end_line",
    "category",
    "category_group",
    "severity",
    "corroboration",
    "primary_message",
    "corroborators",
    "patch_source",
    "context_snippet",
    "source_file_hash",
    "autofixable",
    "tags"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "qzp-finding/1"
    },
    "finding_id": {
      "type": "string",
      "pattern": "^qzp-[0-9]{4}$"
    },
    "file": {
      "type": "string",
      "minLength": 1
    },
    "line": {
      "type": "integer",
      "minimum": 1
    },
    "end_line": {
      "type": "integer",
      "minimum": 1
    },
    "column": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "category_group": {
      "type": "string",
      "enum": ["security", "quality", "style"]
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "corroboration": {
      "type": "string",
      "enum": ["multi", "single"]
    },
    "primary_message": {
      "type": "string"
    },
    "corroborators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Corroborator"
      }
    },
    "fix_hint": {
      "type": ["string", "null"]
    },
    "patch": {
      "type": ["string", "null"]
    },
    "patch_source": {
      "type": "string",
      "enum": ["deterministic", "llm", "none"]
    },
    "patch_confidence": {
      "type": ["string", "null"],
      "enum": ["high", "medium", "low", null]
    },
    "context_snippet": {
      "type": "string"
    },
    "source_file_hash": {
      "type": "string"
    },
    "cwe": {
      "type": ["string", "null"]
    },
    "autofixable": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_error": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "Corroborator": {
      "type": "object",
      "required": [
        "provider",
        "rule_id",
        "original_message",
        "provider_priority_rank"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "rule_id": {
          "type": "string"
        },
        "rule_url": {
          "type": ["string", "null"]
        },
        "original_message": {
          "type": "string"
        },
        "provider_priority_rank": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
